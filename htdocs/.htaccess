# =============================================
# JDC Auto - Configuration sécurité Apache
# =============================================

# Désactiver le listage des répertoires
Options -Indexes

# Bloquer l'accès direct aux fichiers de configuration PHP
<FilesMatch "(admin_auth|mysql_gandi)\.php$">
    Order Allow,Deny
    Deny from all
</FilesMatch>

# Bloquer l'accès direct au dossier config/
<IfModule mod_rewrite.c>
    RewriteRule ^config/ - [F,L]
</IfModule>

# Headers de sécurité
<IfModule mod_headers.c>
    Header always set X-Frame-Options "SAMEORIGIN"
    Header always set X-Content-Type-Options "nosniff"
    Header always set Referrer-Policy "same-origin"
    Header always set Permissions-Policy "camera=(), microphone=(), geolocation=()"
    Header always set X-XSS-Protection "1; mode=block"
</IfModule>

# Empêcher l'accès aux fichiers sensibles
<FilesMatch "\.(env|log|sql|bak|backup|sh|md)$">
    Order Allow,Deny
    Deny from all
</FilesMatch>
